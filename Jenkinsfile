pipeline {
    agent any

     stage('Build WAR') {
            steps {
                sh 'mvn clean package -DskipTests'
            }

    stages {
        stage('Build') {
            steps {
                echo 'Building..'
            }
        }
        stage('Test') {
            steps {
                echo 'Testing..'
            }
        }
        stage('Deploy') {
            steps {
                echo 'Deploying....'
            }
        }
    }
}
